{
  "enabled": true,
  "name": "Auto Commit & Push",
  "description": "Kiroの作業が完了したタイミングで、変更ファイルを自動的にgit add → commit → pushします",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git diff --cached --quiet || git commit -m \"chore: Kiroによる自動コミット\" && git push",
    "timeout": 30
  },
  "workspaceFolderName": "minutes-checker-repo",
  "shortName": "auto-commit-push"
}